--------------------------------------------------------------------------------
-- POST crear urbanización - /urbanizacion/crear/
--------------------------------------------------------------------------------
BEGIN
    ORDS.DEFINE_TEMPLATE(
        p_module_name => 'mod_alicuotas_api',
        p_pattern     => 'urbanizacion/crear/'
    );

    ORDS.DEFINE_HANDLER(
        p_module_name => 'mod_alicuotas_api',
        p_pattern     => 'urbanizacion/crear/',
        p_method      => 'POST',
        p_source_type => ORDS.source_type_plsql,
        p_source      => q'[
            DECLARE
                v_nombre    VARCHAR2(100);
                v_direccion VARCHAR2(200);
                v_ciudad    VARCHAR2(100);
                v_telefono  VARCHAR2(20);
                v_correo    VARCHAR2(100);
            BEGIN
                v_nombre    := JSON_VALUE(:body_text, '$.nombre');
                v_direccion := JSON_VALUE(:body_text, '$.direccion');
                v_ciudad    := JSON_VALUE(:body_text, '$.ciudad');
                v_telefono  := JSON_VALUE(:body_text, '$.telefono');
                v_correo    := JSON_VALUE(:body_text, '$.correo');

                INSERT INTO urbanizacion(nombre, direccion, ciudad, telefono, correo)
                VALUES (v_nombre, v_direccion, v_ciudad, v_telefono, v_correo);

                COMMIT;

                :status_code := 201;
                owa_util.mime_header('application/json', TRUE);
                htp.p('{"mensaje":"Urbanización creada correctamente"}');

            EXCEPTION
                WHEN OTHERS THEN
                    ROLLBACK;
                    :status_code := 400;
                    owa_util.mime_header('application/json', TRUE);
                    htp.p('{"error":"' || REPLACE(SQLERRM, '"', '\"') || '"}');
            END;
        ]'
    );

    COMMIT;
END;
/

--------------------------------------------------------------------------------
-- PUT actualizar urbanización - /urbanizacion/actualizar/
--------------------------------------------------------------------------------
BEGIN
    ORDS.DEFINE_TEMPLATE(
        p_module_name => 'mod_alicuotas_api',
        p_pattern     => 'urbanizacion/actualizar/'
    );

    ORDS.DEFINE_HANDLER(
        p_module_name => 'mod_alicuotas_api',
        p_pattern     => 'urbanizacion/actualizar/',
        p_method      => 'PUT',
        p_source_type => ORDS.source_type_plsql,
        p_source      => q'[
            DECLARE
                v_id        NUMBER;
                v_nombre    VARCHAR2(100);
                v_direccion VARCHAR2(200);
                v_ciudad    VARCHAR2(100);
                v_telefono  VARCHAR2(20);
                v_correo    VARCHAR2(100);
                v_filas     NUMBER;
            BEGIN
                v_id        := TO_NUMBER(JSON_VALUE(:body_text, '$.id_urbanizacion'));
                v_nombre    := JSON_VALUE(:body_text, '$.nombre');
                v_direccion := JSON_VALUE(:body_text, '$.direccion');
                v_ciudad    := JSON_VALUE(:body_text, '$.ciudad');
                v_telefono  := JSON_VALUE(:body_text, '$.telefono');
                v_correo    := JSON_VALUE(:body_text, '$.correo');

                UPDATE urbanizacion
                SET nombre    = NVL(v_nombre, nombre),
                    direccion = NVL(v_direccion, direccion),
                    ciudad    = NVL(v_ciudad, ciudad),
                    telefono  = NVL(v_telefono, telefono),
                    correo    = NVL(v_correo, correo)
                WHERE id_urbanizacion = v_id;

                v_filas := SQL%ROWCOUNT;
