--------------------------------------------------------------------------------
-- GET viviendas - /viviendas/
--------------------------------------------------------------------------------
BEGIN
    ORDS.DEFINE_TEMPLATE(
        p_module_name => 'mod_alicuotas_api',
        p_pattern     => 'viviendas/'
    );

    ORDS.DEFINE_HANDLER(
        p_module_name => 'mod_alicuotas_api',
        p_pattern     => 'viviendas/',
        p_method      => 'GET',
        p_source_type => ORDS.source_type_query,
        p_source      => q'[
SELECT v.*, p.nombres || ' ' || p.apellidos AS propietario, u.nombre AS urbanizacion
FROM vivienda v
LEFT JOIN propietario p ON p.id_propietario = v.id_propietario
LEFT JOIN urbanizacion u ON u.id_urbanizacion = v.id_urbanizacion
ORDER BY v.id_vivienda
        ]'
    );

    COMMIT;
END;
/

