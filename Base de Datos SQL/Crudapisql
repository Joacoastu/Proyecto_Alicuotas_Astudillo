            BEGIN
                v_pregunta := JSON_VALUE(:body_text, '$.pregunta');

                pr_consulta_lenguaje_natural(v_pregunta);

                COMMIT;

                :status_code := 201;
                owa_util.mime_header('application/json', TRUE);
                htp.p('{"mensaje":"Pregunta procesada y guardada en CONSULTA_IA"}');

            EXCEPTION
                WHEN OTHERS THEN
                    ROLLBACK;
                    :status_code := 400;
                    owa_util.mime_header('application/json', TRUE);
                    htp.p('{"error":"' || REPLACE(SQLERRM, '"', '\"') || '"}');
            END;
        ]'
    );

    COMMIT;
END;
