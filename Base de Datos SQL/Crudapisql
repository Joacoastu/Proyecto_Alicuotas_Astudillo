--------------------------------------------------------------------------------
-- GET deudores filtro - /deudores/filtro/:letra/:mes1/:mes2/
--------------------------------------------------------------------------------
BEGIN
    ORDS.DEFINE_TEMPLATE(
        p_module_name => 'mod_alicuotas_api',
        p_pattern     => 'deudores/filtro/:letra/:mes1/:mes2/'
    );

    ORDS.DEFINE_HANDLER(
        p_module_name => 'mod_alicuotas_api',
        p_pattern     => 'deudores/filtro/:letra/:mes1/:mes2/',
        p_method      => 'GET',
        p_source_type => ORDS.source_type_query,
        p_source      => q'[
SELECT DISTINCT
    p.id_propietario, p.cedula, p.nombres, p.apellidos, p.telefono, p.correo,
    v.numero_vivienda, v.manzana, pe.mes, pe.anio, a.valor, a.estado, a.fecha_limite
FROM propietario p
JOIN vivienda v ON v.id_propietario = p.id_propietario
JOIN alicuota a ON a.id_vivienda = v.id_vivienda
JOIN periodo pe ON pe.id_periodo = a.id_periodo
WHERE UPPER(p.apellidos) LIKE UPPER(:letra) || '%'
  AND pe.mes IN (TO_NUMBER(:mes1), TO_NUMBER(:mes2))
  AND a.estado IN ('PENDIENTE', 'VENCIDA')
ORDER BY p.apellidos, p.nombres, pe.mes
        ]'
    );

    COMMIT;
END;
/

