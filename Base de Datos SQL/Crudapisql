                :status_code := 200;
                owa_util.mime_header('application/json', TRUE);
                htp.p('{"mensaje":"Urbanización actualizada","filas_afectadas":' || v_filas || '}');

            EXCEPTION
                WHEN OTHERS THEN
                    ROLLBACK;
                    :status_code := 400;
                    owa_util.mime_header('application/json', TRUE);
                    htp.p('{"error":"' || REPLACE(SQLERRM, '"', '\"') || '"}');
            END;
        ]'
